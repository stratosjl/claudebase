# Force LF line endings for all shell scripts and test fixtures
# This prevents Windows CRLF from breaking grep pattern matching
*.sh text eol=lf
*.bash text eol=lf
*.bats text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cmd text eol=lf

# Marketplace identity fields (name, owner, description) are fork-side; upstream
# merges keep our values via a custom merge driver. Cloners must register the
# driver once by running scripts/setup-merge-driver.sh after clone.
.claude-plugin/marketplace.json merge=keep-fork-marketplace-fields
